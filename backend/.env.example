NODE_ENV=development

# Server
PORT=3000

# Database — development: SQLite by default (no MySQL needed). Set USE_SQLITE=0 to use MySQL.
USE_SQLITE=1
# MySQL (when USE_SQLITE=0)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=medtech_db
DB_USER=root
DB_PASSWORD=

# JWT
JWT_SECRET=change_this_to_a_random_32_character_secret_key
JWT_EXPIRES_IN=7d
REFRESH_SECRET=change_this_to_a_different_random_refresh_secret

# AI Services
CT_SERVICE_URL=http://localhost:8000
XRAY_SERVICE_URL=http://localhost:8001
GEMINI_API_KEY=your_backend_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# Frontend (for CORS in production)
FRONTEND_URL=http://localhost:3001

# Gmail SMTP for OTP email delivery
GMAIL_USER=morganshope40@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
